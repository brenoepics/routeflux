{
  "name": "@routeflux/adapter-vue",
  "version": "0.0.1-alpha.2",
  "description": "Vue route adapter for Routeflux.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brenoepics/routeflux.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "test:coverage": "vp test -- --coverage",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@routeflux/core": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__traverse": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
