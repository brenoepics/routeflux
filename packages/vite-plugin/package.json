{
  "name": "@routeforge/vite-plugin",
  "version": "0.0.0",
  "description": "Vite plugin scaffold for Routeforge.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "test:coverage": "vp test -- --coverage",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@routeforge/adapter-react": "workspace:*",
    "@routeforge/core": "workspace:*",
    "@routeforge/crawler-puppeteer": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  }
}
